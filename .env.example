# Krelvan configuration — copy to .env and edit. ALL VALUES ARE OPTIONAL.
# The web UI and API boot with no secrets. LLM features (building agents from
# natural language, run explanations) need a provider/key; without one the UI
# still runs and clearly reports LLM as off.

# ── Ports ───────────────────────────────────────────────────────────────────
# API server port (the web UI talks to this).
PORT=3201
# Web UI port (used by `npx krelvan` / `docker compose up`).
KRELVAN_WEB_PORT=3100

# ── Data ────────────────────────────────────────────────────────────────────
# Where the SQLite ledger (ledger.db) and JSON registries are written.
# Created automatically on first run if missing.
KRELVAN_DATA_DIR=./data

# ── LLM provider (optional) ──────────────────────────────────────────────────
# Provider: anthropic | openai | gemini | groq | mistral | ollama | compatible
#           (default: anthropic)
# KRELVAN_LLM_PROVIDER=anthropic
# KRELVAN_LLM_API_KEY=sk-...
# KRELVAN_LLM_MODEL=claude-sonnet-4-6
# KRELVAN_LLM_BASE_URL=...   # required for "compatible"; overrides default for others

# Legacy Anthropic-only shortcut (still honoured):
# KRELVAN_ANTHROPIC_KEY=sk-ant-...

# Examples (pick one):
#   Anthropic:  PROVIDER=anthropic  MODEL=claude-sonnet-4-6      API_KEY=sk-ant-...
#   OpenAI:     PROVIDER=openai     MODEL=gpt-4o-mini            API_KEY=sk-...
#   Gemini:     PROVIDER=gemini     MODEL=gemini-2.0-flash       API_KEY=...
#   Groq:       PROVIDER=groq       MODEL=llama-3.3-70b-versatile API_KEY=gsk_...
#   Mistral:    PROVIDER=mistral    MODEL=mistral-large-latest   API_KEY=...
#   Local:      PROVIDER=ollama     MODEL=llama3.2               (no key needed)
#   Any OpenAI-compatible gateway (OpenRouter / Together / Fireworks / vLLM / LM Studio):
#     PROVIDER=compatible  BASE_URL=https://openrouter.ai/api/v1  API_KEY=sk-or-...
#     MODEL=anthropic/claude-sonnet-4-6   (any model slug the gateway exposes)

# ── Marketplace registry (optional) ──────────────────────────────────────────
# The "Discover" tab loads capabilities from this Git-hosted index.json.
# Defaults to the official registry; override to use your own fork.
# NEXT_PUBLIC_KRELVAN_REGISTRY_URL=https://raw.githubusercontent.com/sreenathmmenon/krelvan-registry/main/index.json

# ── Deploy capability secrets (only if you install a deploy.* capability) ─────
# Secrets are referenced by name in a capability YAML ({{secret:<name>}}) and
# resolved from an env var of the SAME name. Create a deploy/build hook in your
# provider and store its URL (or token) under the matching name.
# Vercel:           Project → Settings → Git → Deploy Hooks
# vercel-deploy-hook=https://api.vercel.com/v1/integrations/deploy/...
# Netlify:          Site → Build & deploy → Build hooks
# netlify-build-hook=https://api.netlify.com/build_hooks/...
# Cloudflare Pages: Project → Settings → Builds & deployments → Deploy hooks
# cloudflare-pages-hook=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/...
# Render:           Service → Settings → Deploy Hook
# render-deploy-hook=https://api.render.com/deploy/srv-...
# Railway:          Account/Project → Tokens (used with the GraphQL API + service id)
# railway-token=...

# ── Ledger signing (optional) ─────────────────────────────────────────────────
# A FRESH install signs the ledger with per-install Ed25519 keys by default —
# tamper-evident AND non-repudiable. The public keys are served at
# GET /api/ledger/keys (no auth) so an auditor/regulator/counterparty can
# independently verify the whole ledger WITHOUT any secret (and `npx krelvan verify`
# does this offline), and cannot forge it. Keys live under data/signing-*-ed25519.key
# (chmod 600); the .pub half is publishable. The private key never leaves the signer.
# Force the symmetric HMAC-SHA256 adapter instead (tamper-evident, instance-local):
# KRELVAN_LEDGER_SIGNING=hmac
# (An existing HMAC data dir keeps using HMAC automatically — don't switch it to ed25519,
#  or events signed before the switch will read as tampered.)
# Optional: provide your own Ed25519 PKCS#8 private key PEMs instead of auto-generated:
# KRELVAN_LEDGER_OWNER_PRIVKEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# KRELVAN_LEDGER_SUPERVISOR_PRIVKEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
